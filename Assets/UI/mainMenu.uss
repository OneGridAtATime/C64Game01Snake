.root {
    flex-grow: 1;
    justify-content: center;
    align-items: center;
    background-color: rgb(20, 20, 80);
    padding-left: 24px;
    padding-right: 24px;
}

.title {
    font-size: 36px;
    -unity-font-style: bold;
    color: rgb(160, 200, 255);
    margin-bottom: 24px;
}

.menuButton {
    width: 220px;
    height: 50px;
    margin-bottom: 12px;
    font-size: 20px;
}
